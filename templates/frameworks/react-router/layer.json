{
  "name": "react-router",
  "overrides": [".prettierignore"],
  "packageJson": {
    "scripts": {
      "dev": "react-router dev",
      "dev:e2e": "react-router dev --port 5173 --host 127.0.0.1",
      "build": "react-router build && node scripts/pb-public.mjs",
      "test:e2e": "playwright test",
      "typecheck": "react-router typegen && tsc --noEmit",
      "typegen": "pocketbase-typegen --url $PB_TYPEGEN_URL --email $PB_TYPEGEN_EMAIL --password $PB_TYPEGEN_PASSWORD --out app/lib/pocketbase-types.ts"
    },
    "dependencies": {
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "react-router": "^8.2.0"
    },
    "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@playwright/test": "^1.61.1",
      "@react-router/dev": "^8.2.0",
      "@tailwindcss/vite": "^4.3.2",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2",
      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.3",
      "eslint": "^10.7.0",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.3",
      "globals": "^17.7.0",
      "jsdom": "^29.1.1",
      "tailwindcss": "^4.3.2",
      "typescript": "~5.9.3",
      "typescript-eslint": "^8.64.0",
      "vite": "^8.1.4",
      "vitest": "^4.1.10"
    }
  }
}
