# PocketBase URL the frontend talks to during development.
# In production static mode the app is served by PocketBase itself, so it uses
# the page origin; in SSR mode set this on your frontend host (e.g. Vercel).
NEXT_PUBLIC_POCKETBASE_URL=<%= it.pocketbaseUrl %>
<% if (it.auth.oauth.length > 0) { %>
# OAuth credentials — only needed for a LOCAL `pocketbase serve`. On PocketHost,
# set these in the dashboard (instance → Secrets) instead; never commit them.
<% for (const provider of it.auth.oauth) { %><%= provider.toUpperCase() %>_CLIENT_ID=
<%= provider.toUpperCase() %>_CLIENT_SECRET=
<% } %><% } %>