      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.3",
      "eslint": "^9.39.5",
      "eslint-config-next": "^16.2.10",
      "jsdom": "^29.1.1",
      "tailwindcss": "^4.3.2",
