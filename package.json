{
  "name": "pockethost-cli",
  "version": "0.1.0",
  "description": "Scaffold deploy-ready PocketHost-backed web apps with a single wizard",
  "type": "module",
  "license": "MIT",
  "author": "Patrick Sissons",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patsissons/pockethost-cli.git"
  },
  "keywords": [
    "pockethost",
    "pocketbase",
    "scaffold",
    "cli",
    "generator"
  ],
  "bin": {
    "ph": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:quick": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test",
    "validate": "pnpm validate:quick",
    "format-and-validate": "pnpm format && pnpm validate:quick"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "eta": "^4.6.0",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.0",
    "eslint": "^10.7.0",
    "tsdown": "^0.22.7",
    "tsx": "^4.20.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
